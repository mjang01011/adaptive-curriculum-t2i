{
  "bucket": "complex_composition",
  "description": "Grounded complex composition dataset. Hard eval checks count, attributes, relation; GRPO adds visibility/quality stabilizers.",
  "target_reward_rule": {
    "type": "normalized_hard_target_accuracy",
    "formula": "correct_target_questions / 4",
    "max_reward": 1.0,
    "min_reward": 0.0,
    "vlm_answer_space": [
      "yes",
      "no",
      "uncertain"
    ],
    "uncertain_score": 0.0,
    "used_for": [
      "validation",
      "ucb",
      "final_eval"
    ],
    "note": "Use only target_questions for hard evaluation and UCB updates."
  },
  "grpo_reward_rule": {
    "type": "weighted_pseudo_soft_accuracy",
    "formula": "sum(weight_i * pseudo_soft_correctness_i) / sum(weight_i)",
    "max_reward": 1.0,
    "min_reward": 0.0,
    "vlm_answer_space": [
      "yes",
      "no",
      "uncertain"
    ],
    "pseudo_soft_scoring": {
      "expected_yes": {
        "yes": 1.0,
        "uncertain": 0.5,
        "no": 0.0
      },
      "expected_no": {
        "no": 1.0,
        "uncertain": 0.5,
        "yes": 0.0
      }
    },
    "used_for": [
      "grpo_training"
    ],
    "note": "Use grpo_reward_questions for GRPO training only. Do not use support/quality questions for UCB or final hard evaluation."
  }
}