{
  "bucket": "attribute_binding",
  "target_only": true,
  "description": "Pure attribute-binding bucket. Prompts contain two attributed objects and no explicit count or spatial relation. Reward only checks attribute-to-object binding and anti-swaps.",
  "target_question_count_per_prompt": 4,
  "prompt_reward_rule": "correct_target_questions / 4",
  "templates": [
    {
      "type": "attribute",
      "template": "Is the {object1} {attribute1}?",
      "answer": "yes"
    },
    {
      "type": "attribute",
      "template": "Is the {object2} {attribute2}?",
      "answer": "yes"
    },
    {
      "type": "anti_swap",
      "template": "Is the {object1} {attribute2}?",
      "answer": "no"
    },
    {
      "type": "anti_swap",
      "template": "Is the {object2} {attribute1}?",
      "answer": "no"
    }
  ],
  "reward_rule": {
    "type": "normalized_target_accuracy",
    "formula": "correct_target_questions / 4",
    "max_reward": 1.0,
    "min_reward": 0.0,
    "vlm_answer_space": [
      "yes",
      "no",
      "uncertain"
    ],
    "uncertain_score": 0.0,
    "note": "Use only target_questions for reward computation."
  },
  "non_overlap_note": "No target questions about counting, spatial relations, object existence, or scene context."
}