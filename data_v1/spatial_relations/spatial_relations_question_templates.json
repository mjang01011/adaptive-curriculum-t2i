{
  "bucket": "spatial_relations",
  "target_only": true,
  "description": "Pure spatial-relation bucket. Prompts contain one subject, one object, and one relation. Reward only checks the relation and its inverse/negative.",
  "target_question_count_per_prompt": 2,
  "prompt_reward_rule": "correct_target_questions / 2",
  "relations": {
    "left_of": "to the left of",
    "right_of": "to the right of",
    "above": "above",
    "below": "below",
    "on_top_of": "on top of",
    "under": "under",
    "inside": "inside"
  },
  "inverse_relations": {
    "left_of": "right_of",
    "right_of": "left_of",
    "above": "below",
    "below": "above",
    "on_top_of": "under",
    "under": "on_top_of",
    "inside": "outside_of"
  },
  "templates": [
    {
      "type": "relation",
      "template": "Is the {subject} {relation_phrase} the {object}?",
      "answer": "yes"
    },
    {
      "type": "anti_relation",
      "template": "Is the {subject} {inverse_or_negative_relation_phrase} the {object}?",
      "answer": "no"
    }
  ],
  "reward_rule": {
    "type": "normalized_target_accuracy",
    "formula": "correct_target_questions / 2",
    "max_reward": 1.0,
    "min_reward": 0.0,
    "vlm_answer_space": [
      "yes",
      "no",
      "uncertain"
    ],
    "uncertain_score": 0.0,
    "note": "Use only target_questions for reward computation."
  },
  "non_overlap_note": "No target questions about attributes, counts, object existence, or scene context."
}